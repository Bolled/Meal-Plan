// State
let currentDayIdx = new Date().getDay() === 0 ? 6 : new Date().getDay() - 1;
let viewDate = new Date();

function getDateKey(date) {
  return date.toISOString().split('T')[0];
}

function getChecked(dateKey, mealIdx) {
  const data = JSON.parse(localStorage.getItem('racion_' + dateKey) || '{}');
  return data[mealIdx] || false;
}

function setChecked(dateKey, mealIdx, val) {
  const data = JSON.parse(localStorage.getItem('racion_' + dateKey) || '{}');
  data[mealIdx] = val;
  localStorage.setItem('racion_' + dateKey, JSON.stringify(data));
}

function getDayCheckedCount(dateKey, totalMeals) {
  const data = JSON.parse(localStorage.getItem('racion_' + dateKey) || '{}');
  return Object.values(data).filter(Boolean).length;
}

function renderDay() {
  const dayIdx = currentDayIdx;
  const day = DAYS_DATA[dayIdx];
  const dateKey = getDateKey(viewDate);
  const checkedCount = getDayCheckedCount(dateKey, day.meals.length);

  // Date label
  const dayNames = ['Вс','Пн','Вт','Ср','Чт','Пт','Сб'];
  const months = ['янв','фев','мар','апр','май','июн','июл','авг','сен','окт','ноя','дек'];
  document.getElementById('date-label').textContent =
    `${day.fullName}, ${viewDate.getDate()} ${months[viewDate.getMonth()]}`;

  // Progress
  const pct = Math.round(checkedCount / day.meals.length * 100);
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-text').textContent =
    `${checkedCount} из ${day.meals.length} приёмов выполнено`;

  // Macros (show done portion)
  const doneMeals = day.meals.filter((_, i) => getChecked(dateKey, i));
  const doneKcal = doneMeals.reduce((s, m) => s + m.kcal, 0);
  const doneP = doneMeals.reduce((s, m) => s + m.p, 0);
  const doneF = doneMeals.reduce((s, m) => s + m.f, 0);
  const doneC = doneMeals.reduce((s, m) => s + m.c, 0);

  document.getElementById('macros-display').innerHTML = `
    <div class="macro-card"><div class="macro-val ${doneKcal>0?'partial':''}">${doneKcal}<span style="font-size:11px;color:#666">/${day.total.kcal}</span></div><div class="macro-label">ккал</div></div>
    <div class="macro-card"><div class="macro-val ${doneP>0?'partial':''}">${doneP}<span style="font-size:11px;color:#666">/${day.total.p}</span></div><div class="macro-label">белок г</div></div>
    <div class="macro-card"><div class="macro-val ${doneF>0?'partial':''}">${doneF}<span style="font-size:11px;color:#666">/${day.total.f}</span></div><div class="macro-label">жиры г</div></div>
    <div class="macro-card"><div class="macro-val ${doneC>0?'partial':''}">${doneC}<span style="font-size:11px;color:#666">/${day.total.c}</span></div><div class="macro-label">углев г</div></div>
  `;

  // Day tabs
  const tabsHtml = DAYS_DATA.map((d, i) => {
    const isToday = i === (new Date().getDay() === 0 ? 6 : new Date().getDay() - 1);
    return `<button class="day-tab ${i===dayIdx?'active':''} ${isToday&&i!==dayIdx?'today':''}" onclick="selectDay(${i})">${d.name}</button>`;
  }).join('');
  document.getElementById('day-tabs').innerHTML = tabsHtml;

  // Meals
  let mealsHtml = `<div style="font-size:13px;color:#666;margin-bottom:10px;">${day.type}</div>`;
  day.meals.forEach((meal, i) => {
    const checked = getChecked(dateKey, i);
    mealsHtml += `
      <div class="meal ${checked?'done':''}" id="meal-${i}">
        <div class="meal-header">
          <div class="meal-name">${meal.name}<span>${meal.time}</span></div>
          <div class="meal-kcal">${meal.kcal} ккал</div>
        </div>
        <div class="meal-items">
          ${meal.items.map(item => `<div class="meal-item">• ${item}</div>`).join('')}
        </div>
        <div class="meal-macros">
          <span class="mm">Б: <b>${meal.p}г</b></span>
          <span class="mm">Ж: <b>${meal.f}г</b></span>
          <span class="mm">У: <b>${meal.c}г</b></span>
        </div>
        <button class="check-btn ${checked?'checked':''}" onclick="toggleMeal(${i})">
          ${checked ? '✅ Выполнено' : '○ Отметить как выполненное'}
        </button>
      </div>`;
  });
  document.getElementById('meals-container').innerHTML = mealsHtml;
}

function toggleMeal(mealIdx) {
  const dateKey = getDateKey(viewDate);
  const current = getChecked(dateKey, mealIdx);
  setChecked(dateKey, mealIdx, !current);
  renderDay();
}

function selectDay(idx) {
  currentDayIdx = idx;
  // Adjust viewDate to match selected day
  const today = new Date();
  const todayIdx = today.getDay() === 0 ? 6 : today.getDay() - 1;
  const diff = idx - todayIdx;
  viewDate = new Date(today);
  viewDate.setDate(today.getDate() + diff);
  renderDay();
}

function changeDate(dir) {
  viewDate.setDate(viewDate.getDate() + dir);
  currentDayIdx = viewDate.getDay() === 0 ? 6 : viewDate.getDay() - 1;
  renderDay();
}

function renderStats() {
  const today = new Date();
  const weekGrid = document.getElementById('week-grid');
  const dayNames = ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'];
  let totalDays = 0, totalPct = 0, bestDay = '', bestPct = 0, totalMeals = 0;

  let gridHtml = '';
  for (let i = 0; i < 7; i++) {
    const d = new Date(today);
    const todayIdx = today.getDay() === 0 ? 6 : today.getDay() - 1;
    d.setDate(today.getDate() - todayIdx + i);
    const key = getDateKey(d);
    const data = JSON.parse(localStorage.getItem('racion_' + key) || '{}');
    const checked = Object.values(data).filter(Boolean).length;
    const total = DAYS_DATA[i].meals.length;
    const pct = total > 0 ? Math.round(checked / total * 100) : 0;
    if (checked > 0) {
      totalDays++;
      totalPct += pct;
      totalMeals += checked;
      if (pct > bestPct) { bestPct = pct; bestDay = dayNames[i]; }
    }
    gridHtml += `<div class="week-day ${checked>0?'has-data':''}">
      <div class="week-day-name">${dayNames[i]}</div>
      <div class="week-day-pct">${checked>0?pct+'%':'—'}</div>
    </div>`;
  }
  weekGrid.innerHTML = gridHtml;

  document.getElementById('stat-days').textContent = totalDays;
  document.getElementById('stat-best').textContent = bestDay || '—';
  document.getElementById('stat-avg').textContent = totalDays > 0 ? Math.round(totalPct/totalDays)+'%' : '0%';
  document.getElementById('stat-total').textContent = totalMeals;
}

function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  document.getElementById('nav-' + name).classList.add('active');
  if (name === 'stats') renderStats();
}

function clearData() {
  if (confirm('Сбросить все данные?')) {
    Object.keys(localStorage).filter(k => k.startsWith('racion_')).forEach(k => localStorage.removeItem(k));
    renderDay();
  }
}

// Init
renderDay();
</script>
</body>
</html>
