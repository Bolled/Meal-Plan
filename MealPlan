<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Рацион">
<title>Рацион</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; background: #0f0f0f; color: #f0f0f0; max-width: 430px; margin: 0 auto; padding-bottom: 80px; }

/* Header */
.header { background: #0f0f0f; padding: 54px 16px 12px; position: sticky; top: 0; z-index: 100; border-bottom: 1px solid #1a1a1a; }
.header h1 { font-size: 28px; font-weight: 700; }
.header-sub { font-size: 13px; color: #666; margin-top: 2px; }
.date-row { display: flex; align-items: center; justify-content: space-between; margin-top: 10px; }
.date-label { font-size: 15px; font-weight: 600; color: #fff; }
.date-nav { display: flex; gap: 8px; }
.date-btn { background: #1a1a1a; border: none; color: #fff; width: 32px; height: 32px; border-radius: 50%; font-size: 16px; cursor: pointer; }

/* Progress */
.progress-bar { background: #1a1a1a; height: 4px; margin: 10px 16px 0; border-radius: 2px; }
.progress-fill { background: #4CAF50; height: 4px; border-radius: 2px; transition: width 0.4s ease; }
.progress-text { font-size: 11px; color: #666; text-align: center; margin-top: 4px; padding-bottom: 2px; }

/* Macros */
.macros { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 12px 16px; }
.macro-card { background: #1a1a1a; border-radius: 12px; padding: 10px 8px; text-align: center; }
.macro-val { font-size: 18px; font-weight: 700; color: #4CAF50; }
.macro-val.partial { color: #ff9800; }
.macro-label { font-size: 10px; color: #666; margin-top: 2px; }

/* Day tabs */
.day-tabs { display: flex; gap: 6px; padding: 0 16px 12px; overflow-x: auto; scrollbar-width: none; }
.day-tabs::-webkit-scrollbar { display: none; }
.day-tab { background: #1a1a1a; border: none; color: #888; padding: 7px 14px; border-radius: 20px; font-size: 13px; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
.day-tab.active { background: #4CAF50; color: #000; font-weight: 600; }
.day-tab.today { border: 1px solid #4CAF50; }

/* Meals */
.meals { padding: 0 16px; }
.meal { background: #1a1a1a; border-radius: 16px; padding: 14px; margin-bottom: 10px; transition: opacity 0.2s; }
.meal.done { opacity: 0.6; }
.meal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.meal-name { font-size: 15px; font-weight: 700; }
.meal-name span { color: #555; font-weight: 400; font-size: 13px; margin-left: 6px; }
.meal-kcal { font-size: 12px; color: #888; background: #2a2a2a; padding: 3px 10px; border-radius: 10px; }
.meal-items { margin-bottom: 10px; }
.meal-item { font-size: 14px; color: #ccc; padding: 6px 0; border-bottom: 1px solid #2a2a2a; display: flex; align-items: center; gap: 8px; }
.meal-item:last-child { border-bottom: none; }
.meal-macros { display: flex; gap: 14px; margin-bottom: 12px; }
.mm { font-size: 11px; color: #555; }
.mm b { color: #888; }
.check-btn { width: 100%; background: #2a2a2a; border: none; color: #aaa; padding: 10px; border-radius: 10px; font-size: 14px; cursor: pointer; transition: all 0.2s; font-family: inherit; }
.check-btn.checked { background: #1a3a1a; color: #4CAF50; }
.check-btn:active { transform: scale(0.97); }

/* Bottom nav */
.bottom-nav { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; max-width: 430px; background: #0f0f0f; border-top: 1px solid #1a1a1a; display: flex; padding: 8px 0 20px; z-index: 200; }
.nav-btn { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; background: none; border: none; color: #666; font-size: 10px; cursor: pointer; padding: 4px 0; }
.nav-btn.active { color: #4CAF50; }
.nav-icon { font-size: 22px; }

/* Pages */
.page { display: none; }
.page.active { display: block; }

/* Tips page */
.tips-page { padding: 70px 16px 16px; }
.tips-page h2 { font-size: 22px; font-weight: 700; margin-bottom: 16px; }
.tip-card { background: #1a1a1a; border-radius: 14px; padding: 14px; margin-bottom: 10px; }
.tip-card h3 { font-size: 14px; color: #4CAF50; margin-bottom: 8px; }
.tip-item { font-size: 13px; color: #aaa; padding: 4px 0; display: flex; gap: 8px; }
.tip-item::before { content: "✓"; color: #4CAF50; flex-shrink: 0; }

/* Stats page */
.stats-page { padding: 70px 16px 16px; }
.stats-page h2 { font-size: 22px; font-weight: 700; margin-bottom: 16px; }
.stat-card { background: #1a1a1a; border-radius: 14px; padding: 14px; margin-bottom: 10px; }
.stat-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid #2a2a2a; font-size: 14px; }
.stat-row:last-child { border-bottom: none; }
.stat-row span { color: #4CAF50; font-weight: 600; }
.week-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; margin-top: 8px; }
.week-day { background: #2a2a2a; border-radius: 8px; padding: 8px 4px; text-align: center; }
.week-day.has-data { background: #1a3a1a; }
.week-day-name { font-size: 9px; color: #666; }
.week-day-pct { font-size: 12px; font-weight: 700; color: #4CAF50; margin-top: 2px; }
.clear-btn { width: 100%; background: #2a1a1a; border: none; color: #ff6b6b; padding: 14px; border-radius: 12px; font-size: 14px; cursor: pointer; margin-top: 16px; font-family: inherit; }
</style>
</head>
<body>

